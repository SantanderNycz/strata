{
  "name": "strata-server",
  "version": "1.0.0",
  "description": "Strata GraphQL API — industrial drilling pattern visualiser",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate && node -e \"require('fs').rmSync('node_modules/.prisma',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@apollo/server": "^4.10.4",
    "@prisma/client": "^5.13.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "graphql": "^16.8.1",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0"
  }
}
