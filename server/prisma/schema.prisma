generator client {
  provider = "prisma-client-js"
  // Gera em root/node_modules para que tanto o dev local quanto
  // o Vercel encontrem o cliente no lugar certo
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pattern {
  id          String      @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime    @default(now())
  drillHoles  DrillHole[]
}

model DrillHole {
  id        String  @id @default(uuid())
  patternId String
  pattern   Pattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
  x         Float
  z         Float
  depth     Float
  sequence  Int
}
