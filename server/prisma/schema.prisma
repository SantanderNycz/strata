generator client {
  provider = "prisma-client-js"
  // Gera em root/node_modules para que tanto o dev local quanto
  // o Vercel encontrem o cliente no lugar certo
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pattern {
  id           String        @id @default(uuid())
  name         String
  description  String?
  createdAt    DateTime      @default(now())
  drillHoles   DrillHole[]
  terrainNodes TerrainNode[]
}

model DrillHole {
  id        String  @id @default(uuid())
  patternId String
  pattern   Pattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
  x         Float
  z         Float
  depth     Float
  sequence  Int
}

// Cada nó da malha de terreno 10×10 (11×11 vértices no total).
// gridX / gridZ: índice 0–10, mapeados para coordenadas mundo -10 a +10.
model TerrainNode {
  id        String  @id @default(uuid())
  patternId String
  pattern   Pattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
  gridX     Int
  gridZ     Int
  elevation Float   @default(0)

  @@unique([patternId, gridX, gridZ])
}
